# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Bright Data ---
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_PROFILE_DATASET_ID=     # LinkedIn people-profiles dataset id (e.g. gd_l1viktl72bvl7bjuj0)
BRIGHTDATA_SERP_ZONE=              # SERP API zone name (Web Access -> Add API -> SERP API); used for discovery

# --- Google Sheets (OAuth user flow, not a service account) ---
GOOGLE_OAUTH_CLIENT_SECRETS=./client_secret.json   # OAuth "Desktop app" client downloaded from GCP
GOOGLE_TOKEN_CACHE=./.google_token.json            # written on first auth, reused after
SHEET_ID=                          # target Google Sheet id (lives on the operator's own account)

# --- Optional tunables (defaults shown) ---
MODEL_RANK=claude-haiku-4-5-20251001
MODEL_DRAFT=claude-opus-4-8
POOL_SIZE=40
MIN_RESULTS=10
COST_CEILING_USD=1.00
